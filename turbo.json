{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "backend/dist/**",
        "client-dashboard/dist/**"
      ]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
